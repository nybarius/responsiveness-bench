{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/responsiveness-bench/inference-output-v1.schema.json",
  "title": "Responsiveness Bench inference output",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "claim_layers", "response_moves", "stated_verdict"],
  "properties": {
    "case_id": {"type": "string", "minLength": 1},
    "claim_layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["layer_id", "text", "kind", "layer_kind", "required", "backed"],
        "properties": {
          "layer_id": {"type": "string", "minLength": 1},
          "text": {"type": "string", "minLength": 1},
          "kind": {"enum": ["assertion", "causal", "conditional", "normative", "comparative"]},
          "layer_kind": {"enum": ["explicit", "implicated"]},
          "required": {"type": "boolean"},
          "backed": {"type": "boolean"}
        }
      }
    },
    "response_moves": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["move_id", "text", "act", "target_layer_id", "relation"],
        "properties": {
          "move_id": {"type": "string", "minLength": 1},
          "text": {"type": "string", "minLength": 1},
          "act": {"enum": ["admit", "deny", "qualify", "request_evidence", "counterassert", "deflect", "ignore"]},
          "target_layer_id": {"type": ["string", "null"]},
          "relation": {"enum": ["same", "contradicts", "entails", "narrows_within_scope", "scope_mismatch", "irrelevant", "unknown"]}
        }
      }
    },
    "stated_verdict": {"enum": ["fully_responsive", "partially_responsive", "nonresponsive", "invalid"]}
  }
}
